MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/
MONGODB_DATABASE=db_security
JWT_SECRET=cambia_esto_por_una_clave_segura_minimo_32_caracteres
JWT_EXPIRATION=3600000
NOTIFICATION_SERVICE_URL=http://localhost:5000
FIREBASE_PROJECT_ID=flashbuslogin
# Opción 1: Usar variable de entorno GOOGLE_APPLICATION_CREDENTIALS (recomendado)
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/firebase-service-account.json
# Opción 2: Definir firebase.credentials.path en application.properties (NO RECOMENDADO para producción)
# FIREBASE_CREDENTIALS_PATH=C:\\ruta\\a\\firebase-service-account.json
