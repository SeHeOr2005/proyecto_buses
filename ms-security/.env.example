# ============================================================
# VARIABLES DE ENTORNO - ms-security
# ============================================================
# Copia este archivo como .env y completa los valores.
# Las credenciales de OAuth2 ya están en application.properties
# como valores por defecto. Solo necesitas este archivo si quieres
# sobreescribir esos valores (ej: en producción).
# ============================================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017/bustrack
MONGODB_DATABASE=bustrack

# JWT
JWT_SECRET=mySecretKeyForJWTTokenGenerationThatIsLongEnough
JWT_EXPIRATION=3600000

# Microservicio de notificaciones
NOTIFICATION_SERVICE_URL=http://localhost:5000

# OAuth2 Google (ya configurado en application.properties)
# GOOGLE_CLIENT_ID=tu-client-id
# GOOGLE_CLIENT_SECRET=tu-client-secret

# OAuth2 GitHub (ya configurado en application.properties)
# GITHUB_CLIENT_ID=tu-client-id
# GITHUB_CLIENT_SECRET=tu-client-secret

# Frontend
FRONTEND_URL=http://localhost:4200
